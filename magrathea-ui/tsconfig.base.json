{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@magrathea/product-shell": ["packages/product-shell/src/index.ts"],
      "@magrathea/magrathea-example": ["packages/magrathea-example/src/index.ts"],
      "@magrathea/object-storage-extension": ["packages/object-storage-extension/src/index.ts"]
    },
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals"]
  }
}
