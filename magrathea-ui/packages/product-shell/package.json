{
  "name": "@magrathea/product-shell",
  "version": "0.1.0",
  "description": "Product-neutral composition contracts for Magrathea web applications",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
