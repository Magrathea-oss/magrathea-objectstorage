{
  "adr": 7,
  "title": "ADR 0007: Pluggable S3 API via Spring Boot Auto-Configuration",
  "status": "Accepted",
  "lang": "en",
  "document": {
    "type": "document",
    "title": "ADR 0007: Pluggable S3 API via Spring Boot Auto-Configuration",
    "sections": [
      {
        "id": "_adr_0007_pluggable_s3_api_via_spring_boot_auto_configuration",
        "title": "ADR 0007: Pluggable S3 API via Spring Boot Auto-Configuration",
        "level": 1,
        "blocks": []
      },
      {
        "id": "_status",
        "title": "Status",
        "level": 2,
        "blocks": [
          {
            "type": "paragraph",
            "html": "Accepted"
          }
        ]
      },
      {
        "id": "_context",
        "title": "Context",
        "level": 2,
        "blocks": [
          {
            "type": "paragraph",
            "html": "The project must expose only AWS S3-compatible HTTP APIs. A previous internal JSON REST API was not standard S3 and was removed. The S3 API should be independently loadable so that the storage core can exist without an HTTP S3 adapter."
          }
        ]
      },
      {
        "id": "_decision",
        "title": "Decision",
        "level": 2,
        "blocks": [
          {
            "type": "paragraph",
            "html": "Create a dedicated <code>s3-api</code> module containing:"
          },
          {
            "type": "list",
            "style": "ulist",
            "items": [
              {
                "text": "<code>S3PathRouter</code>",
                "blocks": []
              },
              {
                "text": "<code>S3XmlResponses</code>",
                "blocks": []
              },
              {
                "text": "<code>JacksonXmlCodecConfig</code>",
                "blocks": []
              },
              {
                "text": "<code>S3ApiConfig</code>",
                "blocks": []
              },
              {
                "text": "Cucumber S3 API integration tests",
                "blocks": []
              }
            ]
          },
          {
            "type": "paragraph",
            "html": "The module is loaded through Spring Boot 4 auto-configuration using:"
          },
          {
            "type": "paragraph",
            "html": "``<code>text\nMETA-INF/spring/org.springframework.boot.autoconfigure.AutoConfiguration.imports\n</code>``"
          },
          {
            "type": "paragraph",
            "html": "<code>S3ApiConfig</code> is guarded by:"
          },
          {
            "type": "list",
            "style": "ulist",
            "items": [
              {
                "text": "<code>@ConditionalOnClass({ BucketService.class, ObjectService.class })</code>",
                "blocks": []
              },
              {
                "text": "<code>@ConditionalOnProperty(name = \"s3.api.enabled\", havingValue = \"true\", matchIfMissing = true)</code>",
                "blocks": []
              }
            ]
          }
        ]
      },
      {
        "id": "_consequences",
        "title": "Consequences",
        "level": 2,
        "blocks": [
          {
            "type": "list",
            "style": "ulist",
            "items": [
              {
                "text": "Including <code>s3-api</code> on the classpath activates S3 routes by default.",
                "blocks": []
              },
              {
                "text": "Setting <code>s3.api.enabled=false</code> disables S3 routes at runtime.",
                "blocks": []
              },
              {
                "text": "Removing the <code>s3-api</code> dependency removes the web API completely.",
                "blocks": []
              },
              {
                "text": "<code>object-store-infrastructure</code> contains repository implementations only.",
                "blocks": []
              },
              {
                "text": "No custom non-S3 HTTP API is allowed.",
                "blocks": []
              }
            ]
          }
        ]
      }
    ]
  }
}